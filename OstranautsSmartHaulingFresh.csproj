<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>OstranautsSmartHaulingFresh</AssemblyName>
    <RootNamespace>OstranautsSmartHaulingFresh</RootNamespace>
